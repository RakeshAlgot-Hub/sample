# ============================================================================
# PROPERTY MANAGEMENT SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================================
# This file contains all environment variables required for the backend API.
# Copy this file to .env and update with your actual values.
# IMPORTANT: Never commit .env to version control - use .env.example instead.
# ============================================================================


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# MongoDB connection string and database name

# MongoDB Atlas URI (Required)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# MongoDB database name (Optional, default: "project")
MONGO_DB_NAME=project


# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Secrets and token expiration settings for JWT authentication

# JWT secret key (Required)
# IMPORTANT: Must be at least 32 characters long for security
# Generate with: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_here

# JWT algorithm (Optional, default: "HS256")
JWT_ALGORITHM=HS256

# Access token expiration time in minutes (Optional, default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token expiration time in minutes (Optional, default: 10080 = 7 days)
REFRESH_TOKEN_EXPIRE_MINUTES=10080


# ============================================================================
# CORS & SECURITY
# ============================================================================
# Cross-Origin Resource Sharing and security settings

# Allowed origins for CORS (Required)
# Comma-separated list of domains allowed to access the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,https://yourdomain.com

# Allow credentials (Optional, default: false)
# Set to true if frontend sends cookies or auth headers
ALLOW_CREDENTIALS=false

# Enforce HTTPS (Optional, default: false)
# Set to true in production to redirect all HTTP to HTTPS
ENFORCE_HTTPS=false


# ============================================================================
# PAYMENT PROCESSING - RAZORPAY
# ============================================================================
# Razorpay integration for subscription payments

# Razorpay Key ID (Required for payment processing)
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id

# Razorpay Key Secret (Required for payment processing)
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Razorpay Webhook Secret (Recommended for webhook verification)
# Generate in: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret


# ============================================================================
# EMAIL SERVICE - SENDGRID
# ============================================================================
# Email delivery for OTP, password resets, and notifications

# SendGrid API key (Optional, required if email features are enabled)
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key

# From email address (Optional, required if email features are enabled)
# Should be a verified sender email in your SendGrid account
FROM_EMAIL=noreply@yourdomain.com


# ============================================================================
# OAUTH INTEGRATION
# ============================================================================
# Third-party authentication providers

# Google OAuth Client IDs (Optional)
# Comma-separated list of allowed Google Client IDs for authentication
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_IDS=your_google_client_id_1,your_google_client_id_2


# ============================================================================
# ENVIRONMENT & RUNTIME
# ============================================================================
# Application environment and runtime settings

# Environment name (Optional, default: "production")
# Values: development, staging, production
ENV=production

# Public API paths (Optional)
# Comma-separated list of paths that don't require authentication
# If not set, uses default paths (health, auth, etc.)
PUBLIC_PATHS=/api/v1/health,/api/v1/auth/login,/api/v1/auth/register


# ============================================================================
# SUBSCRIPTION PLANS CONFIGURATION
# ============================================================================
# Customize pricing and resource limits for different subscription tiers
# Format: {plan}{field}=value (e.g., freeProperties=1, proTenants=150)
#
# Limit Meanings:
#   properties: Total number of properties owner can create
#   tenants: Total tenants across ALL properties combined
#   rooms: Max rooms PER property (e.g., pro=50 means 50 rooms per property)
#   staff: Max staff members PER property (e.g., pro=5 means 5 staff per property)
#
# Example: Pro plan with 3 properties
#   - Can create 3 properties total
#   - Can have 150 tenants total (across all 3 properties)
#   - Each property can have max 50 rooms (3 properties × 50 = 150 total rooms possible)
#   - Each property can have max 5 staff (3 properties × 5 = 15 total staff possible)
#
# Price is in smallest currency unit (79 = ₹0.79, 999 = ₹9.99)
# Price text is automatically generated from price value

# FREE PLAN
# Entry-level plan with basic features and limits
freeProperties=1
freeTenants=80
freeRooms=30
freeStaff=3
freePrice=0

# PRO PLAN
# Professional plan with increased limits
proProperties=3
proTenants=150
proRooms=50
proStaff=5
proPrice=79

# PREMIUM PLAN
# Enterprise plan with highest limits and full features
premiumProperties=5
premiumTenants=200
premiumRooms=70
premiumStaff=7
premiumPrice=129